# Na detecção de fraudes, analisa-se dados históricos para detectar dados anômalos.
import pandas as pd

url = "https://storage.googleapis.com/download.tensorflow.org/data/creditcard.csv"

df = pd.read_csv(url)
df.head()

"""A coluna time representa o momento da transação
A coluna ***V1*** até a coluna ***V28*** são variáveis transformadas. Isso significa que os dados originais foram processados utilizando **Técnicas de PCA** para preservar a privacidade. Essas coluna apresentam os padrões das transações.
A coluna ***Amount*** representa o valor da transação.
A coluna ***Class*** é onde será determinada se a transação é ou não é fraudulenta: *0* significada NÃO fraudulenta; *1* significa fraudulenta.

## Problema de Classificação Desbalanceada
"""

# Fraudes são raras, por isso o Modelo pode acabar ignorando a Classe com valor 1 (fraude).
# Calculando a proporção de cada tipo de transação
df['Class'].value_counts(normalize=True)

"""## Feature Engineering

#### Featuring Engineering é a criação ou a transformação de Variáveis a fim de ajudar o Modelo a aprender melhor.
#### Features são as Variáveis originais (de entrada) do Dataset: V1 a V28; Amount; Time.


"""

# TRANSFORMAÇÃO LOGARÍTMICA
import numpy as np

# Criando a variável "Amount_log" para receber a transformação logarítmica dos valores presentes na coluna "Amount"
# A Transfomação Logarítmica diminui a escala dos valores, impactando em valores muito grandes
# O "log1p" é para evitar problemas com valores iguais a zero (0), pois não existe logaritmo de zero (log 0).
df['Amount_log'] = np.log1p(df['Amount'])

# PADRONIZAÇÃO DOS DADOS

# Transformar a Média igual a Zero e o Desvio Padrão igual a 1 para deixar os valores na mesma escala.
from sklearn.preprocessing import StandardScaler

scaler = StandardScaler()

# Armazenando o transformação da Média e do Desvio Padrão num novo Campo "Amount_scaled"
df['Amount_scaled'] = scaler.fit_transform(df[['Amount']])

# PREPARAÇÃO DOS DADOS PARA TREINAR O MODELO
from sklearn.model_selection import train_test_split

# Removendo a Feature (variável de entrada) "Class"
X = df.drop("Class", axis=1)
# y é o Target: variável alvo que queremos encontrar (fraude = 1; NÃO fraude = 0)
y = df["Class"]

X_train, X_test, y_train, y_test = train_test_split(
    X, y, stratify=y, test_size=0.3, random_state=42
)

"""## Logistic Regression"""

from sklearn.linear_model import LogisticRegression

model = LogisticRegression(max_iter=1000)

model.fit(X_train, y_train)

y_pred = model.predict(X_test)

"""A mensagem não indica necessariamente um erro, mas sim que o Modelo não terminou de aprender e por ter alcançado o número máximo de interações.

Solução: Melhorar o Número de Interações e Aumentar a Escala dos Dados


"""

# Gerando um Relatório de Classificação (0 e 1) das Métricas de Avaliação do Modelo
from sklearn.metrics import classification_report

print(classification_report(y_test, y_pred))

# CURVA ROC
# Desempenho do Modelo em Diferentes Limiares de Decisão
# False Positive Rate: transações normais classificadas como fraudes pelo Modelo
# True Positive Rate: transações com fraudes identificadas pelo Modelo (Recall)
from sklearn.metrics import roc_curve, roc_auc_score
import matplotlib.pyplot as plt

y_probs = model.predict_proba(X_test)[:,1]

fpr, tpr, _ = roc_curve(y_test, y_probs)

plt.plot(fpr, tpr)
plt.title("ROC Curve")
plt.xlabel("False Positive Rate")
plt.ylabel("True Positive Rate")
plt.show()

print("AUC:", roc_auc_score(y_test, y_probs))

# PRECISION RECALL CURVE
# Recall: quantidade de transações fraudulentas identificadas pelo Modelo
# Precision: entre as transações classificadas como fraudes, quantas realmente são fraudes
from sklearn.metrics import precision_recall_curve

precision, recall, _ = precision_recall_curve(y_test, y_probs)

plt.plot(recall, precision)
plt.title("Precision-Recall Curve")
plt.xlabel("Recall")
plt.ylabel("Precision")
plt.show()

"""## Balanceamento de Dados"""

# Undersampling
# Reduz a Classe majoritária (0) para ficar no mesmo tamanho da Classe minoritária (1)
fraudes = df[df["Class"] == 1]
normais = df[df["Class"] == 0].sample(len(fraudes), random_state=42)

df_under = pd.concat([fraudes, normais])

# Oversampling
# Cria exemplos sintéticos da Classe minoritária (1), ou seja, aumenta a classe minoritária
from imblearn.over_sampling import SMOTE

smote = SMOTE()

X_res, y_res = smote.fit_resample(X, y)

# RANDOM FOREST
# “n_estimator=50” escolhendo 50 árvores de decisão
# “max_depth=10” limitando a profundidade das árvores para evitar Overfitting.
from sklearn.ensemble import RandomForestClassifier

rf = RandomForestClassifier(
    n_estimators=50,
    max_depth=10,
    class_weight="balanced",
    n_jobs=-1,
    random_state=42
)

rf.fit(X_train, y_train)

y_pred_rf = rf.predict(X_test)

print(classification_report(y_test, y_pred_rf))

"""Recall de 0.76 indica que o Modelo consegue identificar 76% das fraudes.

"""

# PIPELINE
# O Pipeline organiza o fluxo de processamento: um fluxo de padronização e modelagem. Indica melhoras consistentes.
from sklearn.pipeline import Pipeline

pipeline = Pipeline([
    ("Scaler", StandardScaler()),
    ("Model", LogisticRegression(max_iter=1000))
])

pipeline.fit(X_train, y_train)

y_pred = pipeline.predict(X_test)

# THRESHOLD
# O threshold é um valor de referência para classificação da transação entre normal e fraudulenta.
# Quanto menor o valor do threshold mais rigoroso é o Modelo.
# Ex: “threshold = 0.3” indica que valores acima de 0.3 são classificados como fraude.
threshold = 0.3

y_pred_custom = (y_probs > threshold).astype(int)

print(classification_report(y_test, y_pred_custom))

"""## Modelo Avançado - XGBoost

O Modelo Avançado ***XGBoost*** é uma técnica composta por vários Modelos, contendo algoritmos de Árvore de Decisão, que são treinados em sequência. Cada novo Modelo tenta corrigir erros cometidos anteriormente.

A presença de muitos Modelos (muitas Árvores de Decisão) permite o aprendizado sequencial, tornando o Modelo ***XGBoost*** mais poderoso. Por isso, ele é bastante utilizado em competições e no mercado - em aplicações de prevenção a fraudes, a acidentes, etc.


"""

# IMPORTAÇÃO DO DATASET
# Na detecção de fraudes, analisa-se dados históricos para detectar dados anômalos.
import pandas as pd

url = "https://storage.googleapis.com/download.tensorflow.org/data/creditcard.csv"
df = pd.read_csv(url)


# PREPARAÇÃO DOS DADOS PARA TREINAR O MODELO
from sklearn.model_selection import train_test_split

# Removendo a Feature (variável de entrada) "Class"
X = df.drop("Class", axis=1)
# y é o Target: variável alvo que queremos encontrar (fraude = 1; NÃO fraude = 0)
y = df["Class"]

X_train, X_test, y_train, y_test = train_test_split(
    X, y, stratify=y, test_size=0.3, random_state=42
)


# MODELO AVANÇADO - XGBOOST
from xgboost import XGBClassifier

xgb = XGBClassifier(
    scale_pos_weight=10, # Ajuda com Desbalanceamento
    use_label_encoder=False,
    eval_metric="logloss"
)

xgb.fit(X_train, y_train)

y_pred_xgb = xgb.predict(X_test)

# Gerando um Relatório de Classificação (0 e 1) das Métricas de Avaliação do Modelo
from sklearn.metrics import classification_report

print(classification_report(y_test, y_pred_xgb))

"""Em *Precision* houve 93% de acertos quando o Modelo Classificou a transação como **Fraude** (**1**).

O *Recall* identificou 78% de Fraudes.

O *F1-Score* apresentou 85% de Equilíbrio entre as Métricas *Precision* e *Recall*.

## Gráfico de Importância/Peso das Variáveis/Campos (V1 a V28, Time, Amount) do Dataset
"""

import matplotlib.pyplot as plt

importancias = xgb.feature_importances_

plt.bar(range(len(importancias)), importancias)
plt.title("Importância das Variáveis")
plt.show()

"""Quanto maior a barra, maior é a influência da variável na Previsão. A maior barra apresenta padrões de dados anômalos que podem ser classificados como um forte indício de Fraude.

## Ajuste de Hiperparâmetro

O **Ajuste de Hiperparâmetro** é uma técnica para testar automaticamente várias combinações de Parâmetros e encontrar a melhor combinação para melhorar o Modelo.
"""

from sklearn.model_selection import GridSearchCV

param_grid = {
    "max_depth": [3,5],
    "n_estimators": [50,100]
}

grid = GridSearchCV(
    XGBClassifier(eval_metric="logloss"),
    param_grid,
    scoring="recall", # A melhor Métrica de Avaliação do Modelo é a "Recall"
    cv=3
)

grid.fit(X_train, y_train)

print("Melhor modelo:", grid.best_params_)

"""## Explicabilidade (SHAP)

**SHAP** mostra mostra como cada variável influencia a decisão do Modelo
"""

# 1. IMPORTAR A BIBLIOTECA (A correção entra aqui)
import shap

# 2. Criar o explicador para o modelo XGBoost
explainer = shap.Explainer(xgb)
shap_values = explainer(X_test[:100])

# 3. Gerar o gráfico de barras de importância das variáveis
shap.plots.bar(shap_values)

